# ── Clerk Authentication ──────────────────────────────────────────────────────
# Create a Clerk application at https://clerk.com
# Note: Verify Clerk's data residency options for PHIPA/PIPEDA compliance.
# For strict Canadian data residency, evaluate Clerk's EU/Canada region offerings.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/patient
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/patient

# ── Supabase (Canadian data residency) ───────────────────────────────────────
# Create a Supabase project in the Canada (Central) region: ca-central-1
# This keeps all PHI within Canada — required for PHIPA & PIPEDA compliance
# Dashboard: https://supabase.com/dashboard → New project → Region: Canada (Central)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── AI (Anthropic Claude) ────────────────────────────────────────────────────
# Used for AI-assisted referral letter drafting
# IMPORTANT: Ensure your Anthropic usage agreement / DPA covers PHI processing.
# For strict PHIPA compliance, review Anthropic's data handling and consider
# a self-hosted or Canadian-region model if available.
ANTHROPIC_API_KEY=sk-ant-...

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
